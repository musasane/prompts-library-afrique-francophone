# =============================================================================
# .gitignore — Prompts Library
# =============================================================================

# -----------------------------------------------------------------------------
# Systèmes d'exploitation
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Éditeurs / IDE
# -----------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
.history/

# -----------------------------------------------------------------------------
# Node.js (pour markdownlint-cli et outils JS)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn-integrity
package-lock.json.bak

# -----------------------------------------------------------------------------
# Python (si scripts d'automatisation/test)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
.env
.env.local
.env.*.local
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Secrets et clés d'API (NE JAMAIS COMMIT)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets.json
credentials.json
config.local.*
.anthropic_api_key
.openai_api_key

# -----------------------------------------------------------------------------
# Fichiers temporaires et builds
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
.cache/
dist/
build/
out/
.next/
.nuxt/

# -----------------------------------------------------------------------------
# Documentation générée
# -----------------------------------------------------------------------------
_site/
.docusaurus/
.vuepress/dist/

# -----------------------------------------------------------------------------
# Outils LLM locaux / brouillons
# -----------------------------------------------------------------------------
drafts/
.scratch/
*.draft.md
TODO.private.md

# -----------------------------------------------------------------------------
# Archives
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# -----------------------------------------------------------------------------
# Fichiers Office temporaires (utiles si tu joins des livrables Word)
# -----------------------------------------------------------------------------
~$*.docx
~$*.xlsx
~$*.pptx
*.~lock.*
